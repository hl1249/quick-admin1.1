# 复制为 .env 并填写实际值
# cp .env.example .env

# 服务
PORT=3000
NODE_ENV=development
DEBUG=true

# MongoDB
DB_URL=mongodb://127.0.0.1
DB_PORT=27017
DB_NAME=quickAdmin
DB_USER=
DB_PASSWORD=
DB_AUTH_SOURCE=admin

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# 登录与权限
TOKEN_MAX_LIMIT=3
PASSWORD_SECRET=passwordSecret
AUTHORIZATION=authorization
PERMISSION_URLS=/app/admin/
ADMIN_ROLE_ID=admin

# 日志表
LOG_DB_NAME=qa-logs

# 缓存
CACHE_TYPE=memory
CACHE_TTL=604800
CACHE_PREFIX=quickAdmin
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS（可选，逗号分隔多个 origin；不设则允许所有）
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173
