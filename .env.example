
DB_URL=mongodb://43.139.63.227
DB_PORT=27017
DB_NAME=quickAdmin
DB_USER=admin
DB_PASSWORD=admin123
DB_AUTH_SOURCE=admin

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d
PASSWORD_SECRET=passwordSecret-demo

# CACHE_TYPE=memory | redis
CACHE_TYPE=redis
CACHE_TTL=604800
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS（可选，逗号分隔多个 origin；不设则允许所有）
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# OSS（与 src/config/oss.config.ts 对应）
# OSS_PROVIDER=local | tencent | aliyun | qiniu
OSS_PROVIDER=tencent
LOCAL_OSS_ROOT_DIR=uploads
LOCAL_OSS_PUBLIC_BASE_URL=

# 腾讯云 COS（OSS_PROVIDER=tencent 时必填）
TENCENT_OSS_SECRET_ID=
TENCENT_OSS_SECRET_KEY=
TENCENT_OSS_BUCKET=
TENCENT_OSS_REGION=
TENCENT_OSS_DOMAIN=

