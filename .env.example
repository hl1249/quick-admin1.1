# ========== 服务配置 ==========
PORT=3000
NODE_ENV=development
DEBUG=true

# ========== 数据库配置 ==========
DB_URL=mongodb://43.139.63.227
DB_PORT=27017
DB_NAME=quickAdmin
DB_USER=admin
DB_PASSWORD=admin123
DB_AUTH_SOURCE=admin

# ========== Redis 配置 ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== JWT 配置 ==========
JWT_SECRET=your_jwt_secret_key_change_me
JWT_EXPIRES_IN=7d

# ========== 安全配置 ==========
PASSWORD_SECRET=passwordSecret-demo

# ========== 日志配置 ==========
LOG_DB_NAME=qa-logs
LOG_LEVEL=debug

# ========== 缓存配置 ==========
CACHE_TYPE=memory
CACHE_TTL=604800

# ========== CORS 配置 ==========
# 留空表示允许所有来源；多个域名用逗号分隔，例如：https://a.com,https://b.com
CORS_ORIGIN=
